#!/usr/bin/env bash
# wp-dev-sync — CLI for syncing WordPress themes to remote servers.
# @author Renan Diaz <https://reandimo.dev>
set -euo pipefail

VERSION="1.0.0"

# Resolve the real path of this script (follows symlinks from npm -g)
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
WP_SYNC_ROOT="$(cd -P "$(dirname "$SOURCE")/.." && pwd)"

export WP_SYNC_LIB="$WP_SYNC_ROOT/lib"
export WP_SYNC_COMMANDS="$WP_SYNC_ROOT/commands"

# ── Help ─────────────────────────────────────────────────────

show_help() {
    source "$WP_SYNC_LIB/_ui.sh"
    ui_banner "WP Dev Sync" "v$VERSION"

    printf "  %s%sUsage:%s  wp-dev-sync %s<command>%s\n\n" \
        "$C_BRIGHT_WHITE" "$C_BOLD" "$C_RESET" \
        "$C_ACCENT_BRIGHT" "$C_RESET"

    printf "  %s%sCommands:%s\n\n" "$C_ACCENT_BRIGHT" "$C_BOLD" "$C_RESET"
    printf "    %s%s%s  %-12s%s %s%s%s\n" "$C_ACCENT" "$C_BOLD" "$CH_SYNC" "watch" "$C_RESET" "$C_DIM" "Watch for changes and auto-sync to remote" "$C_RESET"
    printf "    %s%s%s  %-12s%s %s%s%s\n" "$C_CYAN" "$C_BOLD" "$CH_ARROW_UP" "push" "$C_RESET" "$C_DIM" "One-time push to remote server" "$C_RESET"
    printf "    %s%s%s  %-12s%s %s%s%s\n" "$C_MAGENTA" "$C_BOLD" "$CH_ARROW_DOWN" "pull" "$C_RESET" "$C_DIM" "One-time pull from remote server" "$C_RESET"
    printf "    %s%s%s  %-12s%s %s%s%s\n" "$C_BRIGHT_GREEN" "$C_BOLD" "$CH_STAR" "tunnel" "$C_RESET" "$C_DIM" "Open public tunnel to remote site" "$C_RESET"
    printf "    %s%s%s  %-12s%s %s%s%s\n" "$C_YELLOW" "$C_BOLD" "$CH_LOCK" "setup" "$C_RESET" "$C_DIM" "Check dependencies and test connection" "$C_RESET"
    printf "    %s%s%s  %-12s%s %s%s%s\n" "$C_BRIGHT_BLUE" "$C_BOLD" "$CH_FILE" "init" "$C_RESET" "$C_DIM" "Create .env file from template" "$C_RESET"
    echo ""

    ui_divider
    echo ""
    printf "  %s%sQuick start:%s\n\n" "$C_ACCENT_BRIGHT" "$C_BOLD" "$C_RESET"
    printf "    %s%s1%s%s  wp-dev-sync init          %s# Create .env in your project%s\n" "$C_ACCENT" "$C_BOLD" "$C_RESET" "$C_BRIGHT_WHITE" "$C_DIM" "$C_RESET"
    printf "    %s%s2%s%s  Edit .env             %s# Set your server credentials%s\n" "$C_ACCENT" "$C_BOLD" "$C_RESET" "$C_BRIGHT_WHITE" "$C_DIM" "$C_RESET"
    printf "    %s%s3%s%s  wp-dev-sync setup         %s# Verify everything works%s\n" "$C_ACCENT" "$C_BOLD" "$C_RESET" "$C_BRIGHT_WHITE" "$C_DIM" "$C_RESET"
    printf "    %s%s4%s%s  wp-dev-sync watch         %s# Start syncing!%s\n" "$C_ACCENT" "$C_BOLD" "$C_RESET" "$C_BRIGHT_WHITE" "$C_DIM" "$C_RESET"
    echo ""
}

# ── Init ─────────────────────────────────────────────────────

cmd_init() {
    source "$WP_SYNC_LIB/_ui.sh"
    local target="$(pwd)/.env"
    local template="$WP_SYNC_ROOT/.env.example"

    ui_banner "WP Dev Sync — Init" "Setting up your project"

    if [ -f "$target" ]; then
        ui_warn_box ".env already exists in this directory"
        ui_detail "Edit it manually or delete it to re-initialize"
        exit 0
    fi

    if [ ! -f "$template" ]; then
        ui_error_box "Template .env.example not found in wp-dev-sync installation"
        exit 1
    fi

    cp "$template" "$target"
    ui_ok "Created ${C_BRIGHT_WHITE}.env${C_RESET} from template"

    # Copy .syncignore if it doesn't exist
    local ignore_target="$(pwd)/.syncignore"
    local ignore_template="$WP_SYNC_ROOT/.syncignore.example"
    if [ ! -f "$ignore_target" ] && [ -f "$ignore_template" ]; then
        cp "$ignore_template" "$ignore_target"
        ui_ok "Created ${C_BRIGHT_WHITE}.syncignore${C_RESET} from template"
    fi

    echo ""
    ui_info "Next steps:"
    ui_step "Edit ${C_BRIGHT_WHITE}.env${C_RESET} with your server credentials"
    ui_step "Edit ${C_BRIGHT_WHITE}.syncignore${C_RESET} to customize excluded files"
    ui_step "Run ${C_ACCENT_BRIGHT}wp-dev-sync setup${C_RESET} to verify"
    echo ""
}

# ── Version ──────────────────────────────────────────────────

cmd_version() {
    source "$WP_SYNC_LIB/_ui.sh"
    printf "\n  %s%swp-dev-sync%s %sv%s%s\n\n" \
        "$C_ACCENT_BRIGHT" "$C_BOLD" "$C_RESET" \
        "$C_DIM" "$VERSION" "$C_RESET"
}

# ── Dispatch ─────────────────────────────────────────────────

COMMAND="${1:-help}"

case "$COMMAND" in
    watch)    source "$WP_SYNC_COMMANDS/watch.sh" ;;
    push)     source "$WP_SYNC_COMMANDS/push.sh" ;;
    pull)     source "$WP_SYNC_COMMANDS/pull.sh" ;;
    tunnel)   source "$WP_SYNC_COMMANDS/tunnel.sh" ;;
    setup)    source "$WP_SYNC_COMMANDS/setup.sh" ;;
    init)     cmd_init ;;
    help|-h|--help)    show_help ;;
    version|-v|--version)   cmd_version ;;
    *)
        source "$WP_SYNC_LIB/_ui.sh"
        ui_error_box "Unknown command: $COMMAND"
        show_help
        exit 1
        ;;
esac
