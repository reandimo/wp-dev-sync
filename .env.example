# =============================================================================
# WP Dev Sync — Configuration
# =============================================================================

# Local directory to sync (relative to this .env or absolute)
LOCAL_PATH=./wp-content/themes/my-theme

# Remote directory on the server
REMOTE_PATH=/var/www/html/wp-content/themes/my-theme

# Protocol: ssh or ftp
SYNC_PROTOCOL=ssh

# Server connection
REMOTE_USER=
REMOTE_HOST=
REMOTE_PORT=22

# FTP only (when SYNC_PROTOCOL=ftp)
REMOTE_PASSWORD=

# Sync behavior
SYNC_EXCLUDE=.git,node_modules,.DS_Store,*.log,.env,public/hot
SYNC_DELETE=false

# Tunnel (optional)
# TUNNEL_TOOL=cloudflared
# TUNNEL_DOMAIN=mysite.com
